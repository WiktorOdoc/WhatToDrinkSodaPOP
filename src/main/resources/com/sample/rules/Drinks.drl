package com.sample.rules;

import com.sample.CSVLoader;
import java.util.Map;


global com.sample.Main gui; //interface with GUI

declare enum QuestionCode 
    MEXICO,
    PWN_NOOBS,
    DIET,
    OSTENTATIOUS,
    ANIMATED,
    BOOST,
    JUGGALO,
    DIRT_AFTERTASTE,
    TAY_ZONDAY,
    BRAZIL,
    ON_THE_DOLE,
    FLUX_CAPACITOR,
    BUBBLE_GUM,
    ALL_NIGHTER,
    TESCO,
    PICNIC,
    BUY_ANY,
    TYLER_PERRY,
    ROOT_BEER,
    TUMMY_ACHE,
    QUALITY,
    HFCS,
    AND_TASTE,
    CHERRY,
    CAFFEINE,
    BACKPACK,
    SING,
    SIMPLER_DAYS;
end

declare enum Drink
    JARRITOS,
	MOUNTAIN_DEW_CODE_RED,
	JOLT,
	MELLO_YELLO,
	BAWLS,
