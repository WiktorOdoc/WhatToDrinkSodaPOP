declare QuestionMapHolder //maps all questions from QuestionCode and questions.csv
    map : java.util.Map<String, String>
end

declare DrinkMapHolder //maps all drink names and file names from Drink enum and drinks.csv
    map : java.util.Map<String, String[]>
end


declare Answer  
    question : QuestionCode
    yes      : boolean
end

declare FinalDrink //list of drinks to recommend
    drinks : java.util.List<String>  
end


//load text from csv
rule "init"
when
    not QuestionMapHolder()
    not DrinkMapHolder()
then
    insert( new QuestionMapHolder( CSVLoader.loadQuestions("/questions.csv") ) );
    insert( new DrinkMapHolder( CSVLoader.loadDrinks("/drinks.csv") ) );
end



rule "First question/Mexico"
when
    not Answer()
    QuestionMapHolder( qm : map )
then
	//sends question data to gui to be displayed, y is boolean answer
	// (as all question are yes/no, so no need for additional fields like possible choices or answers)
    boolean y = gui.ask( (String) qm.get( QuestionCode.MEXICO.name() ) ); 
    insert( new Answer( QuestionCode.MEXICO, y ) );
end


rule "Yes Mexico"
when
    Answer( question == QuestionCode.MEXICO, yes )
then
    insert( new FinalDrink( java.util.Arrays.asList(Drink.JARRITOS.name()) ) );
end


rule "No mexico -> PwN nOobs"
when
    Answer( question == QuestionCode.MEXICO, !yes )
    QuestionMapHolder( qm : map )
then
    boolean y = gui.ask( (String) qm.get( QuestionCode.PWN_NOOBS.name() ) );
    insert( new Answer( QuestionCode.PWN_NOOBS, y ) );
end


rule "Yes PwN n00bs "
when
    Answer( question == QuestionCode.PWN_NOOBS, yes )
then
    insert( new FinalDrink(java.util.Arrays.asList(Drink.MOUNTAIN_DEW_CODE_RED.name(), Drink.JOLT.name(), Drink.MELLO_YELLO.name(), Drink.BAWLS.name())));
end


rule "No pwn noobs -> diet"
when
    Answer( question == QuestionCode.PWN_NOOBS, !yes )
    QuestionMapHolder( qm : map )
then
    boolean y = gui.ask( (String) qm.get( QuestionCode.DIET.name() ) );
    insert( new Answer( QuestionCode.DIET, y ) );
end

