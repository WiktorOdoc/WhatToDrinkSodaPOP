rule "Display final drinks"
when
    FinalDrink( $list : drinks )
    DrinkMapHolder( $dm : map )
then
    String[][] result = new String[$list.size()][];

    int i = 0;
    for (Object drink : $list) {
        result[i++] = (String[]) $dm.get((String)drink);
    }

    gui.showDrinks(result, "Recommended Drinks:", "/images/");
end
